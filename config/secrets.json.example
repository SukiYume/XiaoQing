{
	"inbound_token": "your-secret-token-here",
	"admin_user_ids": [123456789],
	"plugins": {
		"arxiv_filter": {
			"feishu_webhook": "https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook-id"
		},
		"wolframalpha": {
			"appid": "your-wolframalpha-appid"
		},
		"voice": {
			"appid": "your-xfyun-appid",
			"api_secret": "your-xfyun-api-secret",
			"api_key": "your-xfyun-api-key"
		},
		"chat": {
			"token": "pat_your-coze-api-token",
			"bot_id": "your-coze-bot-id",
			"user": "123223",
			"proxy": "",
			"stream": false
		},
		"xiaoqing_chat": {
			"api_url": "http://localhost:8000/v1/chat/completions",
			"api_key": "your-api-key",
			"model": "your-model-name"
		},
		"twitter": {
			"nitter_host": "https://nitter.example.com"
		},
		"signin": {
			"your_service_name": {
				"sid": "your-session-id",
				"stoken": "your-session-token"
			}
		},
		"ads_paper": {
			"ads_token": "your-ads-api-token",
			"api_base": "http://localhost:8000/v1/chat/completions",
			"api_key": "your-api-key",
			"model": "your-model-name"
		}
	}
}
